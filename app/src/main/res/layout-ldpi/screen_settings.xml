<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="fill_parent"
	android:layout_height="fill_parent"
	android:layout_gravity="center_vertical"
	android:orientation="vertical">

	<TextView
	    android:id="@+id/tvHeader"
	    android:layout_width="wrap_content"
	    android:layout_height="wrap_content"
	    android:layout_gravity="center_horizontal"
	    android:text="@string/zztrop_crew_rest_in_the_tropopause"
	    android:textColor="@color/colorWhite50"
	    android:textSize="14dp" >

	</TextView>

	<TextView
	    android:id="@+id/tvSettingsTitle"
	    android:layout_width="wrap_content"
	    android:layout_height="wrap_content"
	    android:layout_gravity="center_horizontal"
	    android:layout_marginTop="8dp"
	    android:text="@string/settings"
	    android:textColor="@color/colorWhite"
	    android:textSize="20dp"
	    android:textStyle="bold" >

	</TextView>

	<ScrollView
	    android:id="@+id/scrollView"
	    style="@style/whiteFrame"
	    android:layout_width="match_parent"
	    android:layout_height="0dp"
	    android:layout_margin="8dp"
	    android:layout_weight="1"
	    android:padding="16dp" >

		<LinearLayout
		    android:id="@+id/linearLayout1"
		    android:layout_width="match_parent"
		    android:layout_height="wrap_content"
		    android:orientation="vertical" >

		    <TextView
		        android:id="@+id/tvMode"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:text="@string/work_mode"
		        android:textColor="@color/colorWhite"
		        android:textSize="16dp"
		        android:textStyle="bold" />

		    <RadioGroup
		        android:id="@+id/rgModeSelection"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content" >

		        <RadioButton
		            android:id="@+id/rbtnCockpitMode1"
		            android:layout_width="wrap_content"
		            android:layout_height="wrap_content"
		            android:text="@string/cockpit"
		            android:textSize="16dp" />

		        <RadioButton
		            android:id="@+id/rbtnCockpitMode2"
		            android:layout_width="wrap_content"
		            android:layout_height="wrap_content"
		            android:text="@string/cockpit_based_on_tkf_ldg"
		            android:textSize="16dp" />

		        <RadioButton
		            android:id="@+id/rbtnCabinMode"
		            android:layout_width="wrap_content"
		            android:layout_height="wrap_content"
		            android:text="@string/cabin"
		            android:textSize="16dp" />
		    </RadioGroup>

		    <TextView
		        android:id="@+id/tvTimePickingSettings"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:layout_marginTop="16dp"
		        android:text="@string/time_selection_mode"
		        android:textColor="@color/colorWhite"
		        android:textSize="16dp"
		        android:textStyle="bold" />

		    <RadioGroup
		        android:id="@+id/rgTimeSelection"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content" >

		        <RadioButton
		            android:id="@+id/rbtnTimeSelectionKeypad"
		            android:layout_width="wrap_content"
		            android:layout_height="wrap_content"
		            android:text="@string/regular_pad"
		            android:textSize="16dp" />

		        <RadioButton
		            android:id="@+id/rbtnTimeSelectionFastpad"
		            android:layout_width="wrap_content"
		            android:layout_height="wrap_content"
		            android:text="@string/fast_pad"
		            android:textSize="16dp" />
		    </RadioGroup>

		    <TextView
		        android:id="@+id/tvMiscellaneous"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:layout_marginTop="16dp"
		        android:text="@string/miscellaneous"
		        android:textColor="@color/colorWhite"
		        android:textSize="16dp"
		        android:textStyle="bold" />

		    <CheckBox
		        android:id="@+id/cbPauseAfterService"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:text="@string/pause_after_service" />

		    <TextView
		        android:id="@+id/tvPatternsToDisplay"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:layout_marginTop="16dp"
		        android:text="@string/patterns_to_display"
		        android:textColor="@color/colorWhite"
		        android:textSize="16dp"
		        android:textStyle="bold" />

		    <Button
		        android:id="@+id/btnPatternFilter"
		        android:layout_width="match_parent"
		        android:layout_height="wrap_content"
		        android:layout_marginTop="8dp"
		        android:text="@string/show_list" />

		    <TextView
		        android:id="@+id/tvSettingsTheme"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content"
		        android:layout_marginTop="16dp"
		        android:text="@string/settingsTheme"
		        android:textColor="@color/colorWhite"
		        android:textSize="16dp"
		        android:textStyle="bold" />

		    <RadioGroup
		        android:id="@+id/rgThemeSelection"
		        android:layout_width="wrap_content"
		        android:layout_height="wrap_content" >

		        <RadioButton
		            android:id="@+id/rbtnThemeAirbus"
		            android:layout_width="wrap_content"
		            android:layout_height="wrap_content"
		            android:text="@string/airbus"
		            android:textSize="16dp" />

		        <RadioButton
		            android:id="@+id/rbtnThemeBoeing"
		            android:layout_width="wrap_content"
		            android:layout_height="wrap_content"
		            android:text="@string/boeing"
		            android:textSize="16dp" />

		        <RadioButton
		            android:id="@+id/rbtnThemeBoeingGrey"
		            android:layout_width="wrap_content"
		            android:layout_height="wrap_content"
		            android:text="@string/boeing_grey"
		            android:textSize="16dp" />
		    </RadioGroup>
		</LinearLayout>

	</ScrollView>

	<Button
	    android:id="@+id/btnSettingsOK"
	    android:layout_width="80dip"
	    android:layout_height="40dp"
	    android:layout_gravity="center_horizontal"
	    android:layout_marginBottom="8dp"
	    android:background="@drawable/btn_small"
	    android:text="@string/ok" />

</LinearLayout>