<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="360dp"
    android:layout_height="fill_parent"
    android:layout_gravity="center_horizontal"
    android:layout_marginBottom="4dp"
    android:layout_marginTop="4dp"
    android:background="@drawable/bevel_down"
    android:orientation="vertical" >

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/zztrop_crew_rest_in_the_tropopause"
        android:textColor="@color/colorWhite50"
        android:textSize="14dp" >
    </TextView>

    <LinearLayout
        android:id="@+id/linlayResultContainer"
        android:layout_width="fill_parent"
        android:layout_height="0dp"
        android:layout_gravity="center_horizontal"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical" >

        <ListView
            android:id="@+id/lvResults"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="?listViewBorder"
            android:cacheColorHint="#00000000" >

            <!--
                 Preview: 
			    listheader=@layout/result_header
			    listitem=@layout/row_result_cabin_6
            -->
        </ListView>

        <LinearLayout
            android:id="@+id/linlayAdjustTimes"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal" >

            <Button
                android:id="@+id/btnDurationMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginRight="6dp"
                android:text="@string/button_minus" />

            <Button
                android:id="@+id/btnShiftMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="6dp"
                android:layout_marginRight="6dp"
                android:text="@string/shift_minus" />

            <ToggleButton
                android:id="@+id/tbtnRound"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="6dp"
                android:layout_marginRight="6dp"
                android:text="@+id/ToggleButton01"
                android:textOff="@string/round"
                android:textOn="@string/round" />

            <Button
                android:id="@+id/btnShiftPlus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="6dp"
                android:layout_marginRight="6dp"
                android:text="@string/shift_plus" />

            <Button
                android:id="@+id/btnDurationPlus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginLeft="6dp"
                android:text="@string/button_plus" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnResultsOK"
        android:layout_width="80dip"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="4dp"
        android:text="@string/ok" >
    </Button>

</LinearLayout>